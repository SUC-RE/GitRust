{% extends "pages/repo/layout.jinja" %}
{% block title %}Settings — {{ repo.owner_name }}/{{ repo.name }}{% endblock %}
{% block repo_content %}
<h2>Repository Settings</h2>
<div class="settings-section">
    <h3>General</h3>
    <form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/settings">
        <div class="form-group">
            <label for="description">Description</label>
            <textarea id="description" name="description" class="form-control">{{ repo.description | default("") }}</textarea>
        </div>
        <div class="form-group">
            <label>
                <input type="checkbox" name="is_private" {% if repo.is_private %}checked{% endif %}>
                Private repository
            </label>
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </form>
</div>
<div class="danger-zone">
    <h3>Danger Zone</h3>
    <p style="font-size:14px;color:var(--color-text-secondary);margin-bottom:12px;">
        Deleting a repository is permanent and cannot be undone.
    </p>
    <form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/settings/delete"
          onsubmit="return confirm('Are you sure you want to delete this repository? This action cannot be undone.');">
        <button type="submit" class="btn btn-danger">Delete this repository</button>
    </form>
</div>
{% endblock %}
