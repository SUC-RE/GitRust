{% extends "pages/repo/layout.jinja" %}
{% block title %}Edit Wiki — {{ repo.name }}{% endblock %}
{% block repo_content %}
<h2>Edit Wiki Page</h2>
<form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/wiki/{{ slug }}/edit">
    <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" class="form-control" value="{{ page.title | default('') }}" required>
    </div>
    <div class="form-group">
        <label for="content">Content (Markdown)</label>
        <textarea id="content" name="content" class="form-control" style="min-height:300px;font-family:var(--font-mono);">{{ page.content | default('') }}</textarea>
    </div>
    <button type="submit" class="btn btn-primary">Save Page</button>
</form>
{% endblock %}
