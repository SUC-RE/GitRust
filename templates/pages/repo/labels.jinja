{% extends "pages/repo/layout.jinja" %}
{% block title %}Labels — {{ repo.owner_name }}/{{ repo.name }}{% endblock %}
{% block repo_content %}
<h2>Labels</h2>
<div style="margin-bottom:24px;padding:16px;background:var(--color-bg-secondary);border-radius:8px;border:1px solid var(--color-border);">
    <h3 style="margin-bottom:12px;font-size:14px;">Create Label</h3>
    <form method="post" action="/{{ repo.owner_name }}/{{ repo.name }}/-/labels" style="display:flex;gap:8px;align-items:end;flex-wrap:wrap;">
        <div class="form-group" style="margin-bottom:0;"><input type="text" name="name" class="form-control" placeholder="Label name" required></div>
        <div class="form-group" style="margin-bottom:0;"><input type="text" name="color" class="form-control" placeholder="#ff0000" style="width:100px;" required></div>
        <div class="form-group" style="margin-bottom:0;"><input type="text" name="description" class="form-control" placeholder="Description (optional)" style="width:180px;"></div>
        <button type="submit" class="btn btn-sm btn-primary">Create</button>
    </form>
</div>
{% if labels | length > 0 %}
<div style="display:flex;flex-wrap:wrap;gap:8px;">
{% for label in labels %}
<div style="background:{{ label.color }}22;border:1px solid {{ label.color }};padding:8px 16px;border-radius:8px;min-width:120px;">
    <span class="label" style="background:{{ label.color }};color:#fff;">{{ label.name }}</span>
    {% if label.description %}<p style="font-size:12px;color:var(--color-text-secondary);margin-top:4px;">{{ label.description }}</p>{% endif %}
</div>
{% endfor %}
</div>
{% else %}
<div class="empty-state"><h3>No labels</h3></div>
{% endif %}
{% endblock %}
