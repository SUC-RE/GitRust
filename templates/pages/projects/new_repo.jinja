{% extends "layout.jinja" %}
{% block title %}New Project — GitRust{% endblock %}
{% block content %}
<div class="container" style="max-width:560px;padding-top:32px;">
    <h1 class="page-title">Create a new project</h1>
    <form method="post" action="/projects/new">
        <div class="form-group">
            <label for="owner_type">Owner</label>
            <select id="owner_type" name="owner_type" class="form-control">
                <option value="user">Personal ({{ current_user.username }})</option>
                <option value="group">Group</option>
            </select>
        </div>
        <div class="form-group">
            <label for="owner_name">Group name (if group owner)</label>
            <input type="text" id="owner_name" name="owner_name" class="form-control" placeholder="my-group">
            <p class="text-small">Leave blank for personal repository.</p>
        </div>
        <div class="form-group">
            <label for="name">Repository Name</label>
            <input type="text" id="name" name="name" class="form-control" required placeholder="my-project">
        </div>
        <div class="form-group">
            <label for="description">Description (optional)</label>
            <textarea id="description" name="description" class="form-control"></textarea>
        </div>
        <div class="form-group">
            <label><input type="checkbox" name="is_private"> Private repository</label>
        </div>
        <button type="submit" class="btn btn-primary">Create Repository</button>
    </form>
</div>
{% endblock %}
